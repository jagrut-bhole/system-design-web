generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum AttemptStatus {
  IN_PROGRESS // user is actively in the interview
  SUBMITTED // user submitted, waiting for AI
  COMPLETED // AI responded, score saved
  ABANDONED // user left mid-attempt
}

// ─── Better Auth required tables ─────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Your custom fields
  dailyCreditLimit Int @default(10) // 10 attempts/day free

  // Relations
  accounts   Account[]
  sessions   Session[]
  attempts   Attempt[]
  dailyUsage DailyUsage[]

  @@map("user")
}

model Account {
  id     String @id @default(cuid())
  userId String

  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

// ─── App tables ───────────────────────────────────────────

model Question {
  id          String     @id @default(cuid())
  title       String // "Design Twitter"
  description String // full problem statement
  difficulty  Difficulty
  category    String // "Social Media" | "Storage" | "Real-time"
  companies   String[] // ["Amazon", "Netflix", "Google"]
  hints       String[] // 3 progressive hints, index 0→1→2
  rubric      Json // scoring criteria per axis
  creditCost  Int        @default(1) // credits deducted per attempt
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  attempts Attempt[]
}

model Attempt {
  id          String @id @default(cuid())
  userId      String
  questionId  String
  roundNumber Int    @default(1) // 1=initial, 2=follow-up 1, 3=follow-up 2

  // The 3 input modes — all optional, at least one required on submit
  canvasSnapshot  String? // JSON.stringify of Excalidraw elements array
  writtenAnswer   String? // free-text explanation
  voiceTranscript String? // Web Speech API transcript

  status      AttemptStatus @default(IN_PROGRESS)
  creditsUsed Int           @default(0)

  startedAt   DateTime  @default(now())
  submittedAt DateTime?

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question     @relation(fields: [questionId], references: [id])
  feedback AIFeedback[]
  score    Score?

  // fast lookup for "user's attempts on question X"
  // fast lookup for in-progress attempts
  @@index([userId, questionId])
  @@index([userId, status])
}

model AIFeedback {
  id        String @id @default(cuid())
  attemptId String

  round      Int // matches attempt.roundNumber
  isFollowUp Boolean @default(false)

  // Snapshot of what user submitted at this round
  userInputSnapshot Json
  // {
  //   canvasElements: [...],
  //   writtenAnswer: "...",
  //   voiceTranscript: "..."
  // }

  // Structured AI response (parsed from Claude's JSON output)
  structuredResponse Json
  // {
  //   strengths: string[],
  //   criticalGaps: string[],
  //   componentFeedback: { [componentName]: "missing|present|well-placed|misused" },
  //   hintIfStuck: string | null,
  //   scores: { scalability, availability, costEfficiency, simplicity, correctness }
  // }

  followUpQuestion String? // the next interviewer question

  createdAt DateTime @default(now())

  attempt Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}

model Score {
  id        String @id @default(cuid())
  attemptId String @unique // one final score per attempt

  // All 1–10
  scalability    Int
  availability   Int
  costEfficiency Int
  simplicity     Int
  correctness    Int
  overall        Int // weighted average based on rubric

  createdAt DateTime @default(now())

  attempt Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
}

model DailyUsage {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime @db.Date // stores only the date, no time
  creditsUsed  Int      @default(0)
  requestCount Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // one row per user per day — upsert friendly
  @@unique([userId, date])
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
